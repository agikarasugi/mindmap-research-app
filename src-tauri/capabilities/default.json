{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "$HOME/**" }, { "path": "/**" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "$HOME/**" }, { "path": "/**" }] },
    { "identifier": "fs:allow-write-file", "allow": [{ "path": "$HOME/**" }, { "path": "/**" }] },
    { "identifier": "fs:allow-read-dir", "allow": [{ "path": "$HOME/**" }, { "path": "/**" }] },
    { "identifier": "fs:allow-exists", "allow": [{ "path": "$HOME/**" }, { "path": "/**" }] }
  ]
}
